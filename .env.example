# Root env file for local Docker Compose (copy to `.env` and fill values).
# Compose loads this via `env_file: .env`. Some vars are also passed as build args.

# -----------------------------------------------------------------------------
# mcp-wrapper — OpenWeatherMap API key (required for wrapper to start)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=

# -----------------------------------------------------------------------------
# backend-agent — Gemini API (required at startup)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=

# Optional: same key, alternate env name supported by langchain-google-genai
# GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# frontend — build-time only (Vite bakes this into the static bundle).
# The browser must reach the backend at this URL. With default compose ports,
# the API is published on the host at http://localhost:8000
# -----------------------------------------------------------------------------
VITE_AGENT_BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - MCP_WRAPPER_URL for the agent is set inside docker-compose.yml to
#   http://mcp-wrapper:8080 so containers talk on the compose network.
# - Service ports: wrapper 8080, backend 8000, frontend 3000 -> nginx 80.
